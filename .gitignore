# Created by https://www.toptal.com/developers/gitignore/api/unrealengine
# Edit at https://www.toptal.com/developers/gitignore?templates=unrealengine

### UnrealEngine ###
# Visual Studio user specific files
.vs/
.vsconfig

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine / IDE
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled / source art files
SourceArt/**/*.png
SourceArt/**/*.tga
SourceArt/**/*.psd
SourceArt/**/*.fbx

# Binary Files
Binaries/*
Plugins/*/Binaries/*
Plugins/**/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/*/Intermediate/*
Plugins/**/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*

### UnrealEngine Patch ###
# Don't ignore icon and splash images for mobile app
!Build/IOS/Resources/
Build/IOS/Resources/*
!Build/IOS/Resources/Graphics/
Build/IOS/Resources/Graphics/*
!Build/IOS/Resources/Graphics/*.png
!Build/Android/res/
Build/Android/res/*
!Build/Android/res/*/
Build/Android/res/*/*
!Build/Android/res/*/*.png

# Ignore plugins binaries on deep subfolders
Plugins/**/Binaries/*
Plugins/**/Intermediate/*

### Dev Git Policy Patch ###
# Git includes only code/config/project/plugin code for developer collaboration

# Keep project descriptor
!*.uproject

# Keep config for shared ini/version sync with SVN
!Config/
!Config/**

# Keep source code
!Source/
!Source/**

# Keep plugin descriptors and plugin code/config
!Plugins/
!Plugins/**/*.uplugin
!Plugins/**/Source/
!Plugins/**/Source/**
!Plugins/**/Config/
!Plugins/**/Config/**

# Exclude plugin content by default
Plugins/**/Content/*
Plugins/**/Content/**

# Exclude main project content and non-code collaboration assets
Content/*
Content/**
Collections/*
Collections/**
Developers/*
Developers/**

# Exclude Unreal assets and common art/media source files
*.uasset
*.umap
*.png
*.jpg
*.jpeg
*.tga
*.psd
*.fbx
*.blend
*.wav
*.mp3
*.mp4
*.avi
*.mov

# Optional: keep text-based docs
!README.md
!*.md

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Logs / temp
*.log
*.tmp